{
  "name": "@isolated-vm/experimental",
  "version": "0.0.9",
  "type": "module",
  "author": "https://github.com/laverdet/",
  "description": "JavaScript sandbox",
  "homepage": "https://github.com/laverdet/isolated-vm#readme",
  "license": "ISC",
  "exports": {
    "./CMakeLists.txt": "./addon/CMakeLists.txt",
    ".": "./dist/isolated-vm.js",
    "./*": "./dist/*.js"
  },
  "imports": {
    "#backend_cjs": {
      "types": "./backend/backend.d.cts",
      "darwin-arm64": "@isolated-vm/experimental-darwin-arm64",
      "darwin-x64": "@isolated-vm/experimental-darwin-x64",
      "linux-arm64-gnu": "@isolated-vm/experimental-linux-arm64-gnu",
      "linux-arm64-musl": "@isolated-vm/experimental-linux-arm64-musl",
      "linux-x64-gnu": "@isolated-vm/experimental-linux-x64-gnu",
      "linux-x64-musl": "@isolated-vm/experimental-linux-x64-musl",
      "win32-x64": "@isolated-vm/experimental-win32-x64",
      "require": "./dist/backend/require.cjs"
    },
    "#backend": {
      "types": "./backend/backend.d.cts",
      "import": "./dist/backend/backend.cjs"
    },
    "#host_cjs": "./dist/backend/host.cjs"
  },
  "scripts": {
    "prepublishOnly": "npx napi prepublish --no-gh-release",
    "test:all": "pnpm run -s test:node && pnpm run -s test:deno && pnpm run -s test:bun",
    "test:bun": "${bun:-bun} test ./test/glob.ts",
    "test:deno": "${deno:-deno} test --no-check --allow-env --allow-ffi --allow-read ./test/**/*.ts",
    "test:node": "${node:-node} --enable-source-maps --expose-gc --test-reporter=spec --test test/**/*.ts"
  },
  "napi": {
    "binaryName": "backend_napi_v8",
    "targets": [
      "aarch64-alpine-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-alpine-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "dependencies": {
    "tslib": "^2.7.0"
  },
  "devDependencies": {
    "@isolated-vm/experimental": "workspace:^",
    "@types/node": "^26.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laverdet/isolated-vm.git"
  }
}
